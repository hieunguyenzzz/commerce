<ul class="mx-auto max-w-full flex justify-center text-gray-600 border-b border-accents-3">
  {% if paginate.previous %}
  <li class="py-xs px-4 relative text-lg -mb-px border-b hover:border-b border-transparent "><a
      href="{{ paginate.previous.url }}" title="{{ paginate.previous.title }}"><svg xmlns="http://www.w3.org/2000/svg"
        width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M14 7L9 12L14 17L14 7Z" fill="#111111" />
      </svg></a></li>
  {% endif %}

  {% for part in paginate.parts %}
  {% if part.is_link %}
  <li class="py-xs px-7 relative text-lg -mb-px border-b hover:border-b border-accents-3">
    <a href="{{ part.url }}" title="">{{ part.title }}</a>
  </li>
  {% else %}
  {% if part.title == paginate.current_page %}
  <li class="py-xs px-7 relative text-lg -mb-px border-b border-primary  text-primary "><span>{{ part.title }}</span>
  </li>
  {% else %}
  <li class="py-xs px-7 relative text-lg -mb-px border-b border-transparent  "><span>{{ part.title }}</span></li>
  {% endif %}
  {% endif %}
  {% endfor %}

  {% if paginate.next %}
  <li class="py-xs px-4 relative text-lg -mb-px border-b hover:border-b border-transparent "><a
      href="{{ paginate.next.url }}" title="{{ paginate.next.title }}"><svg xmlns="http://www.w3.org/2000/svg"
        width="24" height="24" viewBox="0 0 24 24" fill="none">
        <g clip-path="url(#clip0)">
          <path d="M10 17L15 12L10 7L10 17Z" fill="#111111" />
        </g>
        <defs>
          <clipPath id="clip0">
            <rect width="24" height="24" fill="white" transform="translate(0 24) rotate(-90)" />
          </clipPath>
        </defs>
      </svg></a></li>
  {% endif %}
</ul>