      <div class="flex flex-col md:flex-row lg:flex-nowrap justify-between space-y-md lg:space-y-0">
        <button
          type="submit"
          data-variant="flat"
          class="Button_root__24MxS order-1 px-6 text-center mt-6 lg:mt-0 w-full lg:w-0 m-0 lg:order-none flex-1  truncate"
          aria-label="Add to Cart" >Add to Cart</button></div>
      {% endform %}

      <div class=" mt-responsive-lg lg:mt-2xl"></div>
      <div class="space-y-md  pointer-events-none">
        <div tabindex="0" class="w-full pointer-events-auto focus:pointer-events-none group">
          <div class="border-b border-black w-full space-x-3 flex items-center">
