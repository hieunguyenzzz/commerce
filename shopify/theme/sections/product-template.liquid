{% schema %}
{
  "name":"Product",
  "settings": [
    {
      "type": "page",
      "id": "detail",
      "label": "detail"
    },
    {
      "type": "page",
      "id": "sizeAndfit",
      "label": "Size & Fit"
    },{
      "type": "page",
      "id": "fabric",
      "label": "fabric"
    },{
      "type": "page",
      "id": "shippingAndreturn",
      "label": "shipping and return"
    }
  ]
}
{% endschema %}
