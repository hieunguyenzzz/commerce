    </div>
  </div>
  <div class="lg:col-span-5 order-2 lg:order-1 lg:py-2xl">
    <div class="max-w-xs">
      <div class="text-xs lg:text-sm uppercase">{{section.settings.subtitle}}</div>
      <div class="text-2xl mt-2 lg:text-3xl  uppercase">{{section.settings.heading}}</div>
      <div class="text-sm lg:text-base mt-5">{{ section.settings.description}}</div>
    </div><a href="{{section.settings.buttonUrl}}"><button data-variant="flat" class="Button_root__24MxS inline-block mt-5">{{section.settings.buttonText}}</button></a>
  </div>
</div>
